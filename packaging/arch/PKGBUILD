pkgname=mime-dispatch
pkgver=1
pkgrel=1
pkgdesc="Suite of file-type-independent tools dispatched by MIME type"
arch=('x86_64')
license=('MIT')
depends=('perl-file-mimeinfo')
makedepends=('go')
source=()
sha256sums=()

build() {
  cd "$startdir/../.."
  make build OUTDIR="$srcdir" GOFLAGS="-v -trimpath" LDFLAGS="-linkmode=external"
}

package() {
  install -Dm755 "$srcdir/metadata" "$pkgdir/usr/bin/metadata"
  install -Dm755 "$srcdir/mime-dispatch-install" "$pkgdir/usr/bin/mime-dispatch-install"
  install -Dm755 "$srcdir/open" "$pkgdir/usr/bin/open"

  for plugin in metadata-yaml-frontmatter metadata-audio metadata-image; do
    install -Dm755 "$srcdir/$plugin" "$pkgdir/usr/lib/mime-dispatch/$plugin"
    DESTDIR="$pkgdir" "$srcdir/mime-dispatch-install" --vendor \
      "$pkgdir/usr/lib/mime-dispatch/$plugin"
  done
}
