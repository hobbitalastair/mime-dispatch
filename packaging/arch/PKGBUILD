pkgname=mime-dispatch
pkgver=3
pkgrel=1
pkgdesc="Suite of file-type-independent tools dispatched by MIME type"
arch=('x86_64')
license=('MIT')
depends=('perl-file-mimeinfo')
optdepends=('bash-completion: bash completion support' 'python-mutagen: audio tag writing')
makedepends=('go')
source=()
sha256sums=()

build() {
  cd "$startdir/../.."
  make build OUTDIR="$srcdir" GOFLAGS="-v -trimpath" LDFLAGS="-linkmode=external"
}

package() {
  install -Dm755 "$srcdir/metadata" "$pkgdir/usr/bin/metadata"
  install -Dm755 "$srcdir/mime-dispatch-install" "$pkgdir/usr/bin/mime-dispatch-install"
  install -Dm755 "$srcdir/open" "$pkgdir/usr/bin/open"

  for plugin in metadata-yaml-frontmatter metadata-audio metadata-image metadata-audio-write; do
    install -Dm755 "$srcdir/$plugin" "$pkgdir/usr/lib/mime-dispatch/$plugin"
    DESTDIR="$pkgdir" "$srcdir/mime-dispatch-install" --vendor \
      "$pkgdir/usr/lib/mime-dispatch/$plugin"
  done

  install -Dm644 "$startdir/../../completions/metadata.bash" \
    "$pkgdir/usr/share/bash-completion/completions/metadata"
  install -Dm644 "$startdir/../../completions/open.bash" \
    "$pkgdir/usr/share/bash-completion/completions/open"
  install -Dm644 "$startdir/../../completions/mime-dispatch-install.bash" \
    "$pkgdir/usr/share/bash-completion/completions/mime-dispatch-install"
}
