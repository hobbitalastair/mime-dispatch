pkgname=metadata
pkgver=1
pkgrel=1
pkgdesc="CLI tool for manipulating file metadata"
arch=('x86_64')
license=('MIT')
depends=('perl-file-mimeinfo')
makedepends=('go')
source=()
sha256sums=()

build() {
  cd "$startdir/../.."

  go build -v \
    -trimpath \
    -ldflags "-linkmode=external" \
    -o "$srcdir/metadata" ./cmd/metadata

  go build -v \
    -trimpath \
    -ldflags "-linkmode=external" \
    -o "$srcdir/mimetype-install" ./cmd/mimetype-install

  go build -v \
    -trimpath \
    -ldflags "-linkmode=external" \
    -o "$srcdir/metadata-yaml-frontmatter" ./plugins/yaml-frontmatter

  cd "$startdir/../../plugins/audio"
  go build -v \
    -trimpath \
    -ldflags "-linkmode=external" \
    -o "$srcdir/metadata-audio" .

  cd "$startdir/../../plugins/image"
  go build -v \
    -trimpath \
    -ldflags "-linkmode=external" \
    -o "$srcdir/metadata-image" .
}

package() {
  install -Dm755 "$srcdir/metadata" "$pkgdir/usr/bin/metadata"
  install -Dm755 "$srcdir/mimetype-install" "$pkgdir/usr/bin/mimetype-install"

  for plugin in metadata-yaml-frontmatter metadata-audio metadata-image; do
    install -Dm755 "$srcdir/$plugin" "$pkgdir/usr/lib/metadata/$plugin"
    DESTDIR="$pkgdir" "$srcdir/mimetype-install" --vendor \
      "$pkgdir/usr/lib/metadata/$plugin"
  done
}
